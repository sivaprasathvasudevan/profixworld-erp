# ---- Supabase (project ref: toxwbjofyglbyjanxmzv) ----
SUPABASE_URL=https://toxwbjofyglbyjanxmzv.supabase.co
# Public/anon (safe in client) — new key format
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
# SERVER ONLY — never ship to the client. Wrangler secret in prod.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx
# JWT verification: JWKS endpoint (ES256 tokens)
SUPABASE_JWKS_URL=https://toxwbjofyglbyjanxmzv.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://toxwbjofyglbyjanxmzv.supabase.co/auth/v1

# ---- Supabase CLI (for migrations) ----
# Personal access token from Supabase dashboard -> Account -> Access Tokens
SUPABASE_ACCESS_TOKEN=
# DB password (Project Settings -> Database) for `supabase link` / db pull
SUPABASE_DB_PASSWORD=

# ---- Client (Vite) — only VITE_* is exposed to the browser ----
VITE_SUPABASE_URL=https://toxwbjofyglbyjanxmzv.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
VITE_API_BASE_URL=http://localhost:8787
